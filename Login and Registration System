    ofstream writeFile("users.txt", ios::app);

    writeFile << username << " "
              << password << endl;

    writeFile.close();

    cout << "Registration Successful!\n";
}

// Login Function
void loginUser() {

    string username, password;
    string fileUser, filePass;

    bool loginSuccess = false;

    cout << "\n=============== LOGIN ===============\n";

    cout << "Enter Username: ";
    cin >> username;

    cout << "Enter Password: ";
    cin >> password;

    ifstream readFile("users.txt");

    // Read all records
    while(readFile >> fileUser >> filePass) {

        if(username == fileUser &&
           password == filePass) {

            loginSuccess = true;
            break;
        }
    }

    readFile.close();

    if(loginSuccess) {
        cout << "Login Successful!\n";
    }
    else {
        cout << "Invalid Username or Password!\n";
    }
}

// Main Function
int main() {

    int choice;

    do {

        cout << "\n========== LOGIN & REGISTRATION SYSTEM ==========\n";

        cout << "1. Register\n";
        cout << "2. Login\n";
        cout << "3. Exit\n";

        cout << "Enter Your Choice: ";
        cin >> choice;

        switch(choice) {

            case 1:
                registerUser();
                break;

            case 2:
                loginUser();
                break;

            case 3:
                cout << "Program Closed Successfully!\n";
                break;

            default:
                cout << "Invalid Choice!\n";
        }

    } while(choice != 3);

    return 0;
}
